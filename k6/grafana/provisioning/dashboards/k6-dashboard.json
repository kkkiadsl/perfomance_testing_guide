        {
          "alias": "RPS",
          "datasource": { "type": "influxdb" },
          "query": "SELECT non_negative_derivative(count(\"value\"), 1s) FROM \"http_reqs\" WHERE $timeFilter GROUP BY time($__interval) fill(0)",
          "rawQuery": true,
          "refId": "B"
